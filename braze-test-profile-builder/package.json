{
  "name": "braze-test-profile-builder",
  "version": "0.1.0",
  "description": "MCP server for creating, managing and auto-expiring Braze test profiles for the roadsurfer CRM team.",
  "type": "module",
  "bin": {
    "braze-test-profile-builder": "dist/index.js"
  },
  "scripts": {
